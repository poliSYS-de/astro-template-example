---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/site.config';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title={`Ueber mich – ${siteConfig.name}`}
  description={`Lernen Sie ${siteConfig.owner.name} kennen. ${siteConfig.owner.role} aus ${siteConfig.owner.location}.`}
>

  <section class="section">
    <div class="container-narrow">
      <p class="subheadline mb-4">Ueber mich</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-8">{siteConfig.owner.name}</h1>

      <div class="prose prose-lg max-w-none">
        <p class="text-lg text-gray-muted">
          Hier steht die Biografie. Ersetzen Sie diesen Platzhaltertext mit den echten Informationen zum Kunden.
        </p>

        <h2>Erfahrung</h2>
        <p>Beschreibung der beruflichen Erfahrung und Expertise.</p>

        <h2>Philosophie</h2>
        <p>Was den Kunden antreibt und was ihn von anderen unterscheidet.</p>
      </div>

      <div class="mt-12">
        <a href={`${baseUrl}/kontakt`} class="btn-primary">Kontakt aufnehmen</a>
      </div>
    </div>
  </section>

</Layout>
