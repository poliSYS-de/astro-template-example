---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/site.config';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title={`Leistungen – ${siteConfig.name}`}
  description={`Die Leistungen von ${siteConfig.owner.name}: ${siteConfig.branding.tagline}`}
>

  <section class="section">
    <div class="container-wide">
      <div class="text-center mb-16">
        <p class="subheadline mb-4">Leistungen</p>
        <h1 class="text-4xl md:text-5xl font-bold">Meine Services</h1>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="card">
          <h2 class="text-2xl font-bold mb-4">Service 1</h2>
          <p class="text-gray-muted mb-4">
            Detaillierte Beschreibung des ersten Service-Angebots.
          </p>
          <p class="text-xl font-bold text-accent">ab XX EUR</p>
        </div>

        <div class="card">
          <h2 class="text-2xl font-bold mb-4">Service 2</h2>
          <p class="text-gray-muted mb-4">
            Detaillierte Beschreibung des zweiten Service-Angebots.
          </p>
          <p class="text-xl font-bold text-accent">ab XX EUR</p>
        </div>

        <div class="card">
          <h2 class="text-2xl font-bold mb-4">Service 3</h2>
          <p class="text-gray-muted mb-4">
            Detaillierte Beschreibung des dritten Service-Angebots.
          </p>
          <p class="text-xl font-bold text-accent">ab XX EUR</p>
        </div>

        <div class="card">
          <h2 class="text-2xl font-bold mb-4">Service 4</h2>
          <p class="text-gray-muted mb-4">
            Detaillierte Beschreibung des vierten Service-Angebots.
          </p>
          <p class="text-xl font-bold text-accent">auf Anfrage</p>
        </div>
      </div>

      <div class="text-center mt-16">
        <a href={`${baseUrl}/kontakt`} class="btn-primary">Jetzt anfragen</a>
      </div>
    </div>
  </section>

</Layout>
