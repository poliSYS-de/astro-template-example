---
import { siteConfig } from '../config/site.config';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

// Navigation aus Config lesen (ohne CTA-Button)
const navItems = siteConfig.navigation.filter(item => !item.isCTA);
const ctaItem = siteConfig.navigation.find(item => item.isCTA);

const isActive = (href: string) => {
  const normalizedPath = currentPath.replace(/\/$/, '') || '/';
  const normalizedHref = `${baseUrl}${href}`.replace(/\/$/, '') || '/';
  if (href === '/') {
    return normalizedPath === baseUrl || normalizedPath === `${baseUrl}/` || normalizedPath === '/';
  }
  return normalizedPath.startsWith(normalizedHref);
};

// Logo aus Config
const logo = siteConfig.branding.logo;
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-6 py-4">
    <nav class="flex items-center justify-between">
      <!-- Logo -->
      <a href={`${baseUrl}/`} class="flex items-center gap-1">
        {logo.type === 'text' && logo.accentChar ? (
          <span class="text-xl font-bold text-dark">
            {logo.value.split(logo.accentChar)[0]}<span class="text-accent">{logo.accentChar}</span>{logo.value.split(logo.accentChar).slice(1).join(logo.accentChar)}
          </span>
        ) : (
          <span class="text-xl font-bold text-dark">{logo.value}</span>
        )}
      </a>

      <!-- Desktop Navigation (Pill-Style) -->
      <div class="hidden md:flex items-center gap-1 bg-gray-50 rounded-full p-1.5">
        {navItems.map((item) => (
          <a
            href={`${baseUrl}${item.href}`}
            class:list={[
              'px-4 py-2 rounded-full text-sm font-medium transition-all duration-200',
              isActive(item.href)
                ? 'bg-white text-dark shadow-sm'
                : 'text-gray-muted hover:text-dark'
            ]}
          >
            {item.name}
          </a>
        ))}
      </div>

      <!-- CTA Button -->
      {ctaItem && (
        <a
          href={`${baseUrl}${ctaItem.href}`}
          class="hidden md:inline-flex btn-primary"
        >
          {ctaItem.name}
        </a>
      )}

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-dark"
        aria-label="Menue oeffnen"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4">
      <div class="flex flex-col gap-2">
        {navItems.map((item) => (
          <a
            href={`${baseUrl}${item.href}`}
            class:list={[
              'px-4 py-3 rounded-lg font-medium transition-colors',
              isActive(item.href)
                ? 'bg-gray-100 text-dark'
                : 'text-gray-muted hover:bg-gray-50'
            ]}
          >
            {item.name}
          </a>
        ))}
        {ctaItem && (
          <a href={`${baseUrl}${ctaItem.href}`} class="btn-primary text-center mt-2">
            {ctaItem.name}
          </a>
        )}
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
