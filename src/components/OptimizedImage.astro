---
interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  sizes?: string;
  width?: number;
  height?: number;
  fetchpriority?: 'high' | 'low' | 'auto';
}

const {
  src,
  alt,
  class: className = '',
  loading = 'lazy',
  sizes = '(max-width: 640px) 480px, (max-width: 1024px) 960px, 1440px',
  width = 960,
  height = 640,
  fetchpriority,
} = Astro.props;

// Dateiname ohne Erweiterung extrahieren
const parts = src.split('/');
const filename = parts[parts.length - 1];
const name = filename.replace(/\.(jpe?g|jpg|png)$/i, '');
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

// Optimierte Bilder liegen in /images/optimized/
const optimizedBase = `${baseUrl}/images/optimized`;
---

<picture>
  <source
    type="image/webp"
    srcset={`${optimizedBase}/${name}-480w.webp 480w, ${optimizedBase}/${name}-960w.webp 960w, ${optimizedBase}/${name}-1440w.webp 1440w`}
    sizes={sizes}
  />
  <img
    src={src.startsWith('/') ? `${baseUrl}${src}` : src}
    alt={alt}
    class={className}
    loading={loading}
    width={width}
    height={height}
    fetchpriority={fetchpriority}
    decoding={loading === 'eager' ? 'sync' : 'async'}
  />
</picture>
